package views

templ PasswordForgetPage() {
	@BaseLayout("Forgot Password") {
		<div class="flex items-center justify-center min-h-screen">
			<div class="text-center">
				<span class="inline-block px-4 py-2 rounded bg-bg-surface border border-border-subtle text-text-muted font-medium tracking-wide">
					[Under Maintenance]
				</span>
				<div class="mt-6">
					<a href="/login" class="text-sm text-wired-blue hover:underline">Return to Login</a>
				</div>
			</div>
		</div>
	}
}

package views

templ DashboardPage() {
	@AppLayout("Dashboard", "dashboard") {
		<div class="flex items-center justify-center h-[60vh]">
			<div class="text-center">
				<span class="inline-block px-6 py-3 rounded-lg bg-bg-surface border border-border-subtle text-text-muted font-medium tracking-wide shadow-sm text-lg">
					[Under Maintenance]
				</span>
				<p class="mt-4 text-text-muted text-sm">We are working hard to bring you the best dashboard experience.</p>
			</div>
		</div>
	}
}
